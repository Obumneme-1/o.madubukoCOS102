   "metadata": {},
   "source": [
    "BEGIN\n",
    "\n",
    "    INPUT total\n",
    "    PRINT \"Total: \", total\n",
    "\n",
    "    INPUT cash\n",
    "\n",
    "    IF cash >= total THEN\n",
    "\n",
    "        COMPUTE change ← cash - total\n",
    "        PRINT \"Change: \", change\n",
    "\n",
    "    ELSE\n",
    "\n",
    "        PRINT \"Insufficient Funds\"\n",
    "\n",
    "    ENDIF\n",
    "\n",
    "END"
   ]
  },
